# Copy this file to .env.local and fill in your values
# (never commit .env.local — it contains secrets)

# Supabase — from supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Groq — your server-side key (not exposed to the client)
GROQ_API_KEY=gsk_...

# Polar.sh — from polar.sh → Settings → API
POLAR_API_KEY=polar_...
POLAR_WEBHOOK_SECRET=wh_...
POLAR_PRODUCT_ID_PRO=prod_...

# App URL (set this in Vercel dashboard env vars too)
NEXT_PUBLIC_APP_URL=https://wispra-web.vercel.app
